/**
 * HatDauKhaAi - AI Chat Widget (UI + AJAX)
 * - Open/close panel
 * - Send message to backend
 * - Append message bubbles (PHP renders assistant HTML)
 *
 * Note: Backend endpoint: sources/ajax/hatdaukhaai/ai-chat-send.php
 */

(function () {
  "use strict";

  function qs(root, selector) {
    return (root || document).querySelector(selector);
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function logWidgetBootstrapError(scope, error) {
    if (typeof console === "undefined" || typeof console.error !== "function") {
      return;
    }
    console.error("[HDK][AI Widget] " + String(scope || "bootstrap error"), error);
  }

  function normalizeDebugFlag(value) {
    const normalized = String(value == null ? "" : value).trim().toLowerCase();
    if (!normalized) return false;
    return normalized === "1" || normalized === "true" || normalized === "yes" || normalized === "on" || normalized === "debug";
  }

  function buildShortErrorMessage(error) {
    if (!error) return "";
    if (typeof error === "string") {
      return error.slice(0, 600);
    }
    if (error && error.message) {
      return String(error.message).slice(0, 600);
    }
    try {
      return JSON.stringify(error).slice(0, 600);
    } catch (e) {
      return String(error).slice(0, 600);
    }
  }

  function createDebugRequestId(prefix) {
    const head = String(prefix || "pwa").replace(/[^a-z0-9_-]/gi, "").slice(0, 18) || "pwa";
    const rand = Math.random().toString(36).slice(2, 10);
    return head + "-" + Date.now().toString(36) + "-" + rand;
  }

  function renderTextWithBold(text) {
    const s = String(text || "");
    if (!s) return "";

    const parts = s.split(/\*\*([\s\S]+?)\*\*/g);
    let out = "";
    for (let i = 0; i < parts.length; i++) {
      const p = String(parts[i] || "");
      if (!p) continue;

      if (i % 2 === 1) {
        out += "<strong>" + escapeHtml(p) + "</strong>";
      } else {
        out += escapeHtml(p);
      }
    }

    return out.replace(/\n/g, "<br>");
  }


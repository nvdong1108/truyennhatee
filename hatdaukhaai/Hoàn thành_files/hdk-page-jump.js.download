/**
 * HDK Page Jump Popup
 * Popup nhỏ gọn để nhảy đến trang cụ thể trong pagination
 * Mobile-first design theo HatDauKhaAi Design System
 * 
 * Usage:
 * hdkPageJump.show({
 *   currentPage: 1,
 *   totalPages: 100,
 *   onSubmit: (page) => { console.log('Go to page:', page); }
 * });
 */

(function() {
    'use strict';

    // Tạo singleton instance
    const hdkPageJump = {
        popup: null,
        input: null,
        infoText: null,
        minusBtn: null,
        plusBtn: null,
        submitBtn: null,
        currentPage: 1,
        totalPages: 1,
        onSubmit: null,

        /**
         * Khởi tạo DOM nếu chưa có
         */
        init() {
            if (this.popup) return;

            // Tạo HTML structure
            const html = `
                <div class="hdk-page-jump" id="hdkPageJump">
                    <div class="hdk-page-jump-backdrop"></div>
                    <div class="hdk-page-jump-content">
                        <div class="hdk-page-jump-handle"></div>
                        <div class="hdk-page-jump-header">
                            <span class="hdk-page-jump-title">Đi đến trang</span>
                            <button type="button" class="hdk-page-jump-close" aria-label="Đóng">×</button>
                        </div>
                        <div class="hdk-page-jump-body">
                            <div class="hdk-page-jump-info">
                                Trang <strong id="hdkPageJumpCurrent">1</strong> / <strong id="hdkPageJumpTotal">1</strong>
                            </div>
                            <div class="hdk-page-jump-quick">
                                <button type="button" class="hdk-page-jump-quick-btn" data-action="first">Đầu</button>
                                <button type="button" class="hdk-page-jump-quick-btn" data-action="middle">Giữa</button>
                                <button type="button" class="hdk-page-jump-quick-btn" data-action="last">Cuối</button>
                            </div>
                            <div class="hdk-page-jump-input-group">
                                <button type="button" class="hdk-page-jump-stepper" data-action="minus" aria-label="Giảm">−</button>
                                <input type="number" class="hdk-page-jump-input" id="hdkPageJumpInput" min="1" value="1" inputmode="numeric" pattern="[0-9]*">
                                <button type="button" class="hdk-page-jump-stepper" data-action="plus" aria-label="Tăng">+</button>
                            </div>
                            <button type="button" class="hdk-page-jump-submit">
                                <iconify-icon icon="solar:arrow-right-bold" width="18"></iconify-icon>
                                Đi đến trang
                            </button>
                        </div>
                    </div>
                </div>
            `;

            // Append vào body
            document.body.insertAdjacentHTML('beforeend', html);

            // Cache elements
            this.popup = document.getElementById('hdkPageJump');
            this.input = document.getElementById('hdkPageJumpInput');
            this.infoText = {
                current: document.getElementById('hdkPageJumpCurrent'),
                total: document.getElementById('hdkPageJumpTotal')
            };
            this.minusBtn = this.popup.querySelector('[data-action="minus"]');
            this.plusBtn = this.popup.querySelector('[data-action="plus"]');
            this.submitBtn = this.popup.querySelector('.hdk-page-jump-submit');

            // Bind events
            this.bindEvents();
        },

        /**
         * Bind tất cả events
         */
        bindEvents() {
            // Close on backdrop click
            this.popup.querySelector('.hdk-page-jump-backdrop').addEventListener('click', () => this.hide());

            // Close button
            this.popup.querySelector('.hdk-page-jump-close').addEventListener('click', () => this.hide());

            // Stepper buttons
            this.minusBtn.addEventListener('click', () => this.stepValue(-1));
            this.plusBtn.addEventListener('click', () => this.stepValue(1));

            // Quick jump buttons
            this.popup.querySelectorAll('.hdk-page-jump-quick-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const action = btn.dataset.action;
                    if (action === 'first') this.setInputValue(1);
                    else if (action === 'last') this.setInputValue(this.totalPages);
                    else if (action === 'middle') this.setInputValue(Math.ceil(this.totalPages / 2));
                });
            });

            // Input change
            this.input.addEventListener('input', () => this.validateInput());
            this.input.addEventListener('change', () => this.validateInput());

            // Submit button
            this.submitBtn.addEventListener('click', () => this.submit());

            // Enter key to submit
            this.input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    this.submit();
                }
            });

            // Escape key to close
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && this.popup.classList.contains('active')) {
                    this.hide();
                }
            });

            // Long press for continuous stepping
            let stepInterval = null;
            const startStepping = (direction) => {
                this.stepValue(direction);
                stepInterval = setInterval(() => this.stepValue(direction), 100);
            };
            const stopStepping = () => {
                if (stepInterval) {
                    clearInterval(stepInterval);
                    stepInterval = null;
                }
            };

            // Touch events for long press
            [this.minusBtn, this.plusBtn].forEach(btn => {
                const direction = btn.dataset.action === 'minus' ? -1 : 1;
                
                let pressTimer = null;
                
                btn.addEventListener('touchstart', (e) => {
                    pressTimer = setTimeout(() => startStepping(direction), 300);
                }, { passive: true });

                btn.addEventListener('touchend', () => {
                    clearTimeout(pressTimer);
                    stopStepping();
                });

                btn.addEventListener('touchcancel', () => {
                    clearTimeout(pressTimer);
                    stopStepping();
                });

                // Mouse events for desktop
                btn.addEventListener('mousedown', () => {
                    pressTimer = setTimeout(() => startStepping(direction), 300);
                });

                btn.addEventListener('mouseup', () => {
                    clearTimeout(pressTimer);
                    stopStepping();
                });

                btn.addEventListener('mouseleave', () => {
                    clearTimeout(pressTimer);
                    stopStepping();
                });
            });
        },

        /**
         * Hiển thị popup
         * @param {Object} options - { currentPage, totalPages, onSubmit }
         */
        show(options = {}) {
            this.init();

            this.currentPage = options.currentPage || 1;
            this.totalPages = options.totalPages || 1;
            this.onSubmit = options.onSubmit || null;

            // Update UI
            this.infoText.current.textContent = this.currentPage;
            this.infoText.total.textContent = this.totalPages;
            this.input.max = this.totalPages;
            this.setInputValue(this.currentPage);

            // Show popup
            this.popup.classList.add('active');
            document.body.style.overflow = 'hidden';

            // Focus input sau animation
            setTimeout(() => {
                this.input.focus();
                this.input.select();
            }, 300);
        },

        /**
         * Ẩn popup
         */
        hide() {
            if (!this.popup) return;

            this.popup.classList.remove('active');
            document.body.style.overflow = '';
            this.onSubmit = null;
        },

        /**
         * Set giá trị input
         * @param {number} value 
         */
        setInputValue(value) {
            value = Math.max(1, Math.min(this.totalPages, parseInt(value) || 1));
            this.input.value = value;
            this.updateStepperState();
        },

        /**
         * Tăng/giảm giá trị
         * @param {number} direction - 1 hoặc -1
         */
        stepValue(direction) {
            const current = parseInt(this.input.value) || 1;
            this.setInputValue(current + direction);
        },

        /**
         * Validate input value
         */
        validateInput() {
            let value = parseInt(this.input.value);
            if (isNaN(value) || value < 1) value = 1;
            if (value > this.totalPages) value = this.totalPages;
            this.input.value = value;
            this.updateStepperState();
        },

        /**
         * Update trạng thái disabled của stepper buttons
         */
        updateStepperState() {
            const value = parseInt(this.input.value) || 1;
            this.minusBtn.disabled = value <= 1;
            this.plusBtn.disabled = value >= this.totalPages;
        },

        /**
         * Submit và gọi callback
         */
        submit() {
            const page = parseInt(this.input.value);
            
            if (isNaN(page) || page < 1 || page > this.totalPages) {
                // Shake animation để báo lỗi
                this.input.style.animation = 'none';
                this.input.offsetHeight; // Trigger reflow
                this.input.style.animation = 'shake 0.4s ease';
                return;
            }

            if (typeof this.onSubmit === 'function') {
                this.onSubmit(page);
            }

            this.hide();
        }
    };

    // Export to global
    window.hdkPageJump = hdkPageJump;

    // Add shake animation CSS
    const style = document.createElement('style');
    style.textContent = `
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-5px); }
            40%, 80% { transform: translateX(5px); }
        }
    `;
    document.head.appendChild(style);

})();

